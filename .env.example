# Inner Warden — environment variables
# Copy this file to .env and fill in your values.
# The agent loads .env automatically on startup (dotenvy).
# In production, set these as real environment variables instead.

# OpenAI API key (required when ai.provider = "openai")
OPENAI_API_KEY=sk-...

# Anthropic API key (for when the Anthropic provider is implemented)
# ANTHROPIC_API_KEY=sk-ant-...

# Override log level (default: info)
# RUST_LOG=innerwarden_agent=debug
